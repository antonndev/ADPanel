          <script nonce="<%= cspNonce %>">
            (function () {
              const CHRISTMAS_IMG = '/images/ADPanel-christmas.png';
              const NORMAL_IMG = '/images/ADPanel-dark.png';

              function isChristmasPeriod() {
                const now = new Date();
                const month = now.getMonth();
                const day = now.getDate();
                return month === 11 && day >= 25 && day <= 28;
              }

              function isChristmasDay() {
                const now = new Date();
                return now.getMonth() === 11 && now.getDate() === 25;
              }

              function applyChristmasTheme() {
                if (!isChristmasPeriod()) return;

                const favicon = document.getElementById('favicon') || document.querySelector('link[rel="icon"]');
                if (favicon) favicon.href = CHRISTMAS_IMG;

                document.querySelectorAll('img').forEach(img => {
                  if (img.src && (img.src.includes('ADPanel-dark.webp') || img.src.includes('i.imgur.com/k5agjYf'))) {
                    img.src = CHRISTMAS_IMG;
                  }
                });
              }

              function showChristmasPopup() {
                if (!isChristmasDay()) return;

                const today = new Date().toDateString();
                const seenKey = 'ADPanel_christmas_seen_' + today;
                if (localStorage.getItem(seenKey)) return;

                const modal = document.getElementById('christmasModal');
                if (!modal) return;

                modal.classList.add('show');
                localStorage.setItem(seenKey, 'true');

                const closeBtn = document.getElementById('christmasClose');
                if (closeBtn) {
                  closeBtn.addEventListener('click', () => modal.classList.remove('show'));
                }

                modal.addEventListener('click', (e) => {
                  if (e.target === modal || e.target.classList.contains('christmas-glass-layer')) {
                    modal.classList.remove('show');
                  }
                });
              }

              function isNewYearDay() {
                const now = new Date();
                return now.getMonth() === 0 && now.getDate() === 1;
              }

              function showNewYearPopup() {
                if (!isNewYearDay()) return;

                const today = new Date().toDateString();
                const seenKey = 'ADPanel_newyear_seen_' + today;
                if (localStorage.getItem(seenKey)) return;

                const modal = document.getElementById('newyearModal');
                if (!modal) return;

                modal.classList.add('show');
                localStorage.setItem(seenKey, 'true');

                const closeBtn = document.getElementById('newyearClose');
                if (closeBtn) {
                  closeBtn.addEventListener('click', () => modal.classList.remove('show'));
                }

                modal.addEventListener('click', (e) => {
                  if (e.target === modal || e.target.classList.contains('newyear-glass-layer')) {
                    modal.classList.remove('show');
                  }
                });
              }

              document.addEventListener('DOMContentLoaded', () => {
                applyChristmasTheme();
                showChristmasPopup();
                showNewYearPopup();
              });
            })();
          </script>
