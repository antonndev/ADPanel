<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="dashboard.css?v=20260308-glassfix">
  <title>ADPanel</title>
  <link id="favicon" rel="icon" type="image/png"
    href="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/adpanel-dark.webp" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.cdnfonts.com/css/gg-sans-2" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

  <link rel="stylesheet" href="/css/dashboard.css?v=20260308-glassfix">
  <link rel="stylesheet" href="/css/dashboard-assistant.css?v=20260320-assistant-enterprise">
  <style nonce="<%= cspNonce %>">
    *,
    *::before,
    *::after {
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      user-select: none;
    }

    img,
    video,
    canvas {
      -webkit-user-drag: none;
      -khtml-user-drag: none;
      -moz-user-drag: none;
      -o-user-drag: none;
      user-drag: none;
      pointer-events: auto;
    }
  </style>
  <script nonce="<%= cspNonce %>">
    document.addEventListener('contextmenu', e => e.preventDefault());
    document.addEventListener('dragstart', e => e.preventDefault());
    document.addEventListener('selectstart', e => e.preventDefault());
    document.addEventListener('copy', e => e.preventDefault());
    document.addEventListener('cut', e => e.preventDefault());
    document.addEventListener('keydown', e => {
      if ((e.ctrlKey || e.metaKey) && (e.key === 'c' || e.key === 'C' || e.key === 'a' || e.key === 'A' || e.key === 's' || e.key === 'S' || e.key === 'u' || e.key === 'U')) {
        e.preventDefault();
      }
    });
  </script>
</head>

<body data-server-start-time="<%= serverStartTime %>">
  <div id="splash-screen"></div>

  <svg xmlns="http://www.w3.org/2000/svg" class="mysvg">
    <defs>
      <filter id="glass-distortion" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.008 0.008" numOctaves="2" seed="92" result="noise" />
        <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
        <feDisplacementMap in="SourceGraphic" in2="blurred" scale="77" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  <header class="top-bar" id="topBar">
    <div class="brand">
      <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/adpanel-dark.webp" alt="ADPanel logo"
        class="brand-logo" />
      <div class="brand-copy">
        <h1 class="brand-title">ADPanel</h1>
        <p class="brand-subtitle">Smart control for your servers</p>
      </div>
    </div>

    <% if (typeof globalAlert !=='undefined' && globalAlert && globalAlert.message) { %>
      <div
        style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); background: rgba(255, 100, 100, 0.1); padding: 8px 16px; border-radius: 99px; display: flex; align-items: center; gap: 8px; color: #ffcccc; pointer-events: none;">
        <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/alert.webp" width="25" height="20" alt="">
        <span style="font-size: 14px; font-weight: 500;">
          <%= globalAlert.message %>
        </span>
      </div>
      <% } %>

        <div class="toolbar">
          <div class="toolbar-actions">
            <% if (isAdmin) { %>
              <button id="createBtn" class="btn-primary create-btn" title="Create">
                <i class="fa-solid fa-plus"></i>
                <span>Create</span>
              </button>
              <% } %>

                <% if (isAdmin) { %>
                  <button class="icon-button" title="Settings" data-href="/settings">
                    <i class="fa-solid fa-bars"></i>
                  </button>
                  <% } else { %>
                    <button class="icon-button" title="You are not admin" disabled>
                      <i class="fa-solid fa-lock"></i>
                    </button>
                    <% } %>
                      <div class="toolbar-assistant">
                        <button id="dashboardAssistantButton" class="icon-button dashboard-assistant-trigger"
                          title="Open ADPanel Assistant" aria-haspopup="dialog" aria-expanded="false">
                          <i class="fa-solid fa-wand-magic-sparkles"></i>
                        </button>

                        <section id="dashboardAssistantMenu" class="dashboard-assistant-menu" hidden aria-hidden="true"
                          aria-label="ADPanel Assistant">
                          <div class="dashboard-assistant-head">
                            <div class="dashboard-assistant-head-copy">
                              <p class="dashboard-assistant-kicker">Voice Workspace</p>
                              <h2 class="dashboard-assistant-title">ADPanel Assistant</h2>
                              <p class="dashboard-assistant-subtitle">
                                Talk to your panel, keep context, and run allowed actions instantly.
                              </p>
                            </div>
                            <div class="dashboard-assistant-head-actions">
                              <button id="dashboardAssistantConfigToggle" class="dashboard-assistant-head-btn"
                                title="Assistant settings" hidden>
                                <i class="fa-solid fa-key"></i>
                              </button>
                              <button id="dashboardAssistantReset" class="dashboard-assistant-head-btn"
                                title="Start a new chat">
                                <i class="fa-solid fa-rotate-right"></i>
                              </button>
                              <button id="dashboardAssistantClose" class="dashboard-assistant-head-btn"
                                title="Close assistant">
                                <i class="fa-solid fa-xmark"></i>
                              </button>
                            </div>
                          </div>

                          <div id="dashboardAssistantStatus" class="dashboard-assistant-status" data-state="idle">
                            Assistant ready.
                          </div>

                          <div id="dashboardAssistantConfig" class="dashboard-assistant-config" hidden>
                            <p class="dashboard-assistant-config-title">Assistant provider</p>
                            <p class="dashboard-assistant-config-text">
                              Save one shared provider key here and every authenticated user on this panel will be able
                              to use the assistant.
                            </p>

                            <form id="dashboardAssistantTokenForm" class="dashboard-assistant-token-form">
                              <label class="dashboard-assistant-token-label" for="dashboardAssistantProviderSelect">
                                Provider
                              </label>
                              <select id="dashboardAssistantProviderSelect" class="dashboard-assistant-token-input">
                                <option value="groq">Groq</option>
                                <option value="google">Google AI Studio</option>
                              </select>
                              <label class="dashboard-assistant-token-label" for="dashboardAssistantTokenInput">
                                <span id="dashboardAssistantTokenLabel">API key</span>
                              </label>
                              <input id="dashboardAssistantTokenInput" class="dashboard-assistant-token-input"
                                type="password" placeholder="Paste the selected provider API key" autocomplete="off">
                              <div class="dashboard-assistant-token-foot">
                                <span id="dashboardAssistantTokenState" class="dashboard-assistant-token-state">
                                  No AI provider key has been saved yet.
                                </span>
                                <button id="dashboardAssistantSaveToken" class="dashboard-assistant-save" type="submit">
                                  Save
                                </button>
                              </div>
                            </form>
                          </div>

                          <div id="dashboardAssistantNotice" class="dashboard-assistant-notice" hidden></div>

                          <div id="dashboardAssistantMessages" class="dashboard-assistant-messages" aria-live="polite">
                          </div>

                          <div class="dashboard-assistant-composer">
                            <form id="dashboardAssistantComposerForm" class="dashboard-assistant-text-form">
                              <label class="dashboard-assistant-text-label" for="dashboardAssistantTextInput">
                                Message
                              </label>
                              <div class="dashboard-assistant-text-row">
                                <textarea id="dashboardAssistantTextInput" class="dashboard-assistant-text-input"
                                  rows="2" placeholder="Ask ADPanel Assistant..." autocomplete="off"></textarea>
                                <button id="dashboardAssistantSend" class="dashboard-assistant-send-btn" type="submit"
                                  title="Send message">
                                  <i class="fa-solid fa-paper-plane"></i>
                                </button>
                              </div>
                            </form>
                            <div class="dashboard-assistant-voicepad">
                              <button id="dashboardAssistantMic" class="dashboard-assistant-voice-btn" type="button"
                                title="Start voice input">
                                <span class="dashboard-assistant-voice-icon">
                                  <i class="fa-solid fa-microphone"></i>
                                </span>
                                <span class="dashboard-assistant-voice-copy">Tap to talk</span>
                              </button>
                              <button id="dashboardAssistantReplay" class="dashboard-assistant-replay-btn" type="button"
                                title="Replay last assistant reply">
                                <i class="fa-solid fa-volume-high"></i>
                              </button>
                            </div>
                            <div class="dashboard-assistant-voice-meta">
                              <div id="dashboardAssistantVoiceState" class="dashboard-assistant-voice-state">
                                Voice replies are on.
                              </div>
                              <div id="dashboardAssistantSpeaking" class="dashboard-assistant-speaking" hidden>
                                <span class="dashboard-assistant-speaking-wave"></span>
                                <span class="dashboard-assistant-speaking-wave"></span>
                                <span class="dashboard-assistant-speaking-wave"></span>
                              </div>
                            </div>
                            <div id="dashboardAssistantTranscript" class="dashboard-assistant-transcript" hidden></div>
                            <div class="dashboard-assistant-composer-note">
                              Type first or use voice. Sensitive account and delete actions still use secure ADPanel
                              confirmations.
                            </div>
                          </div>
                        </section>
                      </div>
                      <button id="accountBtn" class="icon-button account-avatar-btn" title="Manage account">
                        <img src="<%= avatarUrl %>" alt="Avatar" class="account-btn-avatar" draggable="false">
                      </button>
                      <button id="logoutBtn" class="icon-butt" title="Log Out">
                        <i class="fa-solid fa-right-from-bracket"></i>
                      </button>
          </div>
        </div>
  </header>

  <div id="topbar-spacer" aria-hidden="true"></div>

  <main class="dashboard" id="mainContent">
    <section class="hero">
      <div class="hero-copy">
        <h2>Welcome back!</h2>
        <p>
          Monitor, deploy, and orchestrate servers with ease. Launch new experiences for your community in
          seconds.
        </p>

        <div class="hero-actions">
          <button class="pills" data-scroll-target="bots">View Servers</button>
          <% if (isAdmin) { %>
            <button class="pill pill--outline" id="createBtnHero">
              <i class="fa-solid fa-plus" class="faplusbutton"></i>Create
            </button>
            <% } %>
        </div>
      </div>

      <div class="hero-stats">
        <article class="stat-card">
          <div class="stat-card__icon stat-card__icon--active">
            <i class="fa-solid fa-server"></i>
          </div>
          <div class="stat-card__content">
            <p class="stat-card__label">Active servers</p>
            <p class="stat-card__value">
              <%= bots.length %>
            </p>
          </div>
        </article>

        <article class="stat-card">
          <div class="stat-card__icon stat-card__icon--uptime">
            <i class="fa-solid fa-signal"></i>
          </div>
          <div class="stat-card__content">
            <p class="stat-card__label">Status</p>
            <p class="stat-card__value">Operational</p>
          </div>
        </article>

        <article class="stat-card">
          <div class="stat-card__icon stat-card__icon--deploy">
            <i class="fa-solid fa-clock"></i>
          </div>
          <div class="stat-card__content">
            <p class="stat-card__label">Server Uptime</p>
            <p class="stat-card__value" id="uptimeDisplay">0s</p>
          </div>
        </article>
      </div>
    </section>

    <% if (quickActions && quickActions.length> 0) { %>
      <section class="quick-actions" aria-label="Quick actions">
        <h3>Quick actions</h3>
        <div class="quick-actions__grid">
          <% quickActions.forEach(function(action) { %>
            <button
              class="quick-action<%= action.animation && action.animation !== 'default' && action.animation !== 'none' ? ` qa-anim-${action.animation}` : '' %>"
              data-href="<%= action.link %>" <%=action.newTab ? ' data-target="_blank"' : '' %>
              style="<%= action.animation==='scale' ? `--hover-scale: ${action.scaleValue || 1.05}` : '' %>">
                <i class="<%= action.icon || 'fa-solid fa-star' %>"></i>
                <p>
                  <%= action.title %>
                </p>
            </button>
            <% }); %>
        </div>
      </section>
      <% } %>

        <section class="bots" id="servers">
          <div class="section-heading">
            <div>
              <h3>Your servers</h3>
              <p>Browse and jump straight into any workspace.</p>
            </div>
            <div class="section-actions">
              <label for="searchBots" class="search-field">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input id="searchBots" class="search-servers" type="text" placeholder="Search servers" />
              </label>
            </div>
          </div>

          <div class="bot-grid" data-bot-grid>
            <% bots.forEach(function(bot){ const coverStyle=bot.templateImage ?
              `--bot-cover:url('${String(bot.templateImage).replace(/'/g, "\\'" )}');` : '' ; const ipPort=bot.port ?
              `${bot.ip}:${bot.port}` : bot.ip; const memory=bot.memory || {}; const disk=bot.disk || {}; const
              cpuPercent=bot.cpuPercent !==null && bot.cpuPercent !==undefined ? bot.cpuPercent : 0; const
              cpuLimit=bot.cpuLimit || 100; const cpuBarWidth=cpuLimit > 0 ? Math.min(100, (cpuPercent / cpuLimit) * 100) : 0; const
              statusClass=bot.status==='online' ? 'status-online' : (bot.status==='stopped' ? 'status-stopped'
              : 'status-unknown' ) ; const nodeOffline=bot.nodeOnline===false; %>
              <article class="bot-card <%= statusClass %><%= nodeOffline ? ' node-offline' : '' %>" data-bot-card
                data-name="<%= bot.name.toLowerCase() %>" data-cover="<%= bot.templateImage ? bot.templateImage : '' %>"
                data-href="/server/<%= bot.name %>">
                <div class="bot-card__offline" data-offline-overlay
                  style="display: <%= nodeOffline ? 'flex' : 'none' %>;">
                  <div class="offline-ring"></div>
                  <div class="offline-text">Can't establish connection to the server</div>
                </div>
                <div class="bot-card__body">
                  <div class="bot-card__hero">
                    <div class="bot-card__hero-bg"></div>
                    <div class="bot-card__hero-overlay"></div>
                    <div class="bot-card__hero-content">
                      <div class="bot-card__title-row">
                        <div>
                          <h4>
                            <%= bot.displayName || bot.name %>
                          </h4>
                          <p>Node: <%= bot.nodeName %>
                          </p>
                        </div>
                        <div class="bot-card__status <%= statusClass %>">
                          <span class="bot-card__status-dot"></span>
                        </div>
                      </div>
                      <div class="bot-card__meta-row">
                        <span><i class="fa-solid fa-globe"></i>
                          <%= ipPort %>
                        </span>
                        <span><i class="fa-solid fa-cube"></i>
                          <%= bot.templateId || 'Custom' %>
                        </span>
                      </div>
                    </div>
                  </div>

                  <div class="bot-card__stats">
                    <div class="bot-card__stat">
                      <div class="bot-card__stat-label">
                        <div class="bot-card__stat-icon bot-card__stat-icon--memory"><i class="fa-solid fa-memory"></i>
                        </div>
                        <div class="bot-card__stat-title">Memory</div>
                        <div class="bot-card__stat-chip"><i class="fa-solid fa-wave-pulse"></i><span>
                            <%= memory.label || 'N/A' %>
                          </span></div>
                      </div>
                      <div class="bot-card__progress">
                        <span style="width:<%= memory.percent != null ? memory.percent : 0 %>%"></span>
                      </div>
                    </div>
                    <div class="bot-card__stat">
                      <div class="bot-card__stat-label">
                        <div class="bot-card__stat-icon bot-card__stat-icon--disk"><i
                            class="fa-solid fa-hard-drive"></i>
                        </div>
                        <div class="bot-card__stat-title">Disk</div>
                        <div class="bot-card__stat-chip"><i class="fa-solid fa-arrows-rotate"></i><span>
                            <%= disk.label || 'N/A' %>
                          </span></div>
                      </div>
                      <div class="bot-card__progress"><span
                          style="width:<%= disk.percent != null ? disk.percent : 0 %>%"></span></div>
                    </div>
                    <div class="bot-card__stat">
                      <div class="bot-card__stat-label">
                        <div class="bot-card__stat-icon bot-card__stat-icon--cpu"><i class="fa-solid fa-microchip"></i>
                        </div>
                        <div class="bot-card__stat-title">CPU</div>
                        <div class="bot-card__stat-chip"><i class="fa-solid fa-signal"></i><span>
                            <%= bot.cpu || 'N/A' %>
                          </span></div>
                      </div>
                      <div class="bot-card__progress"><span style="width:<%= cpuBarWidth %>%"></span></div>
                    </div>
                  </div>

                  <div class="bot-card__footer">
                    <div class="bot-card__footer-text">Click to view details</div>
                    <i class="fa-solid fa-arrow-right bot-card__chevron"></i>
                  </div>
                </div>
              </article>
              <% }) %>
          </div>
          <% if (pagination && pagination.totalPages > 1) { %>
          <div class="nodes-pagination" id="dashPagination" style="margin-top:16px">
            <div class="nodes-pagination-inner">
              <span class="nodes-pagination-info"><%= ((pagination.page - 1) * pagination.limit) + 1 %>–<%= Math.min(pagination.page * pagination.limit, pagination.total) %> of <%= pagination.total %> servers</span>
              <div class="nodes-pagination-btns">
                <button class="btn ghost btn-sm" <%= pagination.page <= 1 ? 'disabled' : '' %> data-dash-page="<%= pagination.page - 1 %>"><i class="fa-solid fa-chevron-left"></i></button>
                <span class="nodes-pagination-current">Page <%= pagination.page %> / <%= pagination.totalPages %></span>
                <button class="btn ghost btn-sm" <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %> data-dash-page="<%= pagination.page + 1 %>"><i class="fa-solid fa-chevron-right"></i></button>
              </div>
            </div>
          </div>
          <% } %>
        </section>

  </main>

  <div id="accountPage" class="account-page" style="display: none;">
    <div class="account-header">
      <button id="accountBackBtn" class="account-back-btn">
        <i class="fa-solid fa-arrow-left"></i>
        <span>Back to Dashboard</span>
      </button>
      <h2>My Account</h2>
      <p>View and manage your account information</p>
    </div>

    <div class="account-tabs">
      <button class="account-tab active" data-account-tab="info">
        <i class="fa-solid fa-circle-info"></i>
        <span>Info</span>
      </button>
      <button class="account-tab" data-account-tab="credentials">
        <i class="fa-solid fa-key"></i>
        <span>Credentials</span>
      </button>
    </div>

    <div id="accountInfoTab" class="account-tab-content active">
      <div class="account-card">
        <div class="account-card-header">
          <div class="account-avatar" id="accountAvatarWrapper" title="Click to change avatar">
            <img id="accountAvatarImg" src="https://icon-library.com/images/guest-account-icon/guest-account-icon-1.jpg"
              alt="Avatar">
            <div class="account-avatar-overlay">
              <i class="fa-solid fa-camera"></i>
              <span>Change</span>
            </div>
          </div>
          <div class="account-info">
            <h3 id="accountUsername">Loading...</h3>
            <p id="accountEmail">Loading...</p>
          </div>
        </div>

        <input type="file" id="avatarFileInput" accept="image/jpeg,image/png,image/gif,image/webp"
          style="display:none;">

        <div class="account-section-title">
          <i class="fa-solid fa-circle-info"></i>
          Account Details
        </div>

        <div class="account-row account-row-editable" id="usernameRow">
          <span class="account-row-label">Username</span>
          <div class="account-row-value-wrap">
            <span class="account-row-value" id="accountUsernameValue">—</span>
            <input type="text" class="account-row-input" id="usernameInput" style="display:none;" maxlength="30"
              placeholder="Enter username">
            <button class="account-row-edit-btn" id="usernameEditBtn" title="Edit username">
              <i class="fa-solid fa-pencil"></i>
            </button>
            <button class="account-row-save-btn" id="usernameSaveBtn" style="display:none;" title="Save">
              <i class="fa-solid fa-check"></i>
            </button>
            <button class="account-row-cancel-btn" id="usernameCancelBtn" style="display:none;" title="Cancel">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
          <div class="account-row-cooldown" id="usernameCooldown" style="display:none;"></div>
        </div>

        <div class="account-row">
          <span class="account-row-label">Email Address</span>
          <span class="account-row-value" id="accountEmailValue">—</span>
        </div>

        <div class="account-row">
          <span class="account-row-label">Role</span>
          <span class="account-row-value" id="accountRoleValue">—</span>
        </div>

        <div class="account-row">
          <span class="account-row-label">User ID</span>
          <span class="account-row-value" id="accountIdValue">—</span>
        </div>

        <div class="account-row account-row-editable" id="statusRow">
          <span class="account-row-label">Status</span>
          <div class="account-row-value-wrap">
            <span class="account-row-value account-status-value" id="accountStatusValue">
              <span class="status-dot"></span>
              <span id="accountStatusText">Available</span>
            </span>
            <button class="account-row-edit-btn" id="statusEditBtn" title="Edit status">
              <i class="fa-solid fa-pencil"></i>
            </button>
          </div>
        </div>
      </div>
    </div>

    <div id="accountCredentialsTab" class="account-tab-content">
      <div class="account-card">
        <div class="credentials-card">
          <div class="credentials-info">
            <div class="credentials-icon">
              <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/adpanel-dark.webp" alt="2FA" draggable="false">
            </div>
            <div class="credentials-text">
              <h4>Two-Factor Authentication</h4>
              <p>Change your authenticator app 2FA code</p>
            </div>
          </div>
          <button class="credentials-btn" id="change2faBtn">
            <i class="fa-solid fa-rotate"></i> Change 2FA
          </button>
        </div>
      </div>

      <div class="account-card">
        <div class="credentials-card">
          <div class="credentials-info">
            <div class="credentials-icon">
              <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/change-password.webp" alt="Password"
                draggable="false">
            </div>
            <div class="credentials-text">
              <h4>Change Password</h4>
              <p>Update your account password</p>
            </div>
          </div>
          <button class="credentials-btn" id="changePasswordBtn">
            <i class="fa-solid fa-key"></i> Change Password
          </button>
        </div>
      </div>

      <div class="account-card">
        <div class="credentials-card">
          <div class="credentials-info">
            <div class="credentials-icon">
              <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/email.webp" alt="Email" draggable="false">
            </div>
            <div class="credentials-text">
              <h4>Change Email</h4>
              <p>Update your account email address</p>
            </div>
          </div>
          <button class="credentials-btn" id="changeEmailBtn">
            <i class="fa-solid fa-envelope"></i> Change Email
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="dashboardAssistantDeleteModal" class="enterprise-modal-overlay dashboard-assistant-confirm-overlay"
