<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Maintenance Mode</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
  <link rel="icon" type="image/png" sizes="16x16" href="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/adpanel-dark.webp" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <style nonce="<%= cspNonce %>">
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; -webkit-user-select: none; -moz-user-select: none; user-select: none; }
    html, body { height: 100%; overflow: hidden; }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #0a0a0f;
      color: #e2e8f0;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 600px 400px at 20% 30%, rgba(239, 68, 68, 0.06), transparent),
        radial-gradient(ellipse 500px 350px at 80% 70%, rgba(168, 85, 247, 0.05), transparent),
        radial-gradient(ellipse 400px 300px at 50% 50%, rgba(59, 130, 246, 0.04), transparent);
      z-index: 0;
    }
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
      background-size: 60px 60px;
      z-index: 0;
    }
    .maintenance-container {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 560px;
      padding: 48px 40px;
      background: rgba(15, 15, 25, 0.85);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 24px;
      backdrop-filter: blur(20px);
      box-shadow: 0 32px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.03);
    }
    .maintenance-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 28px;
      background: linear-gradient(135deg, rgba(239, 68, 68, 0.15), rgba(168, 85, 247, 0.15));
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      color: #ef4444;
    }
    .maintenance-title {
      font-size: 26px;
      font-weight: 800;
      letter-spacing: -0.5px;
      margin-bottom: 12px;
      background: linear-gradient(135deg, #fff 0%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .maintenance-message {
      font-size: 15px;
      line-height: 1.7;
      color: #94a3b8;
      margin-bottom: 28px;
    }
    .maintenance-reason {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      font-size: 13px;
      color: #cbd5e1;
      margin-bottom: 28px;
    }
    .maintenance-reason i {
      color: #f59e0b;
      font-size: 14px;
    }
    .maintenance-divider {
      height: 1px;
      background: rgba(255, 255, 255, 0.06);
      margin: 0 -40px 20px;
    }
    .maintenance-footer {
      font-size: 12px;
      color: #475569;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }
    .maintenance-footer i {
      font-size: 11px;
    }
    .maintenance-dot {
      width: 6px;
      height: 6px;
      background: #ef4444;
      border-radius: 50%;
      display: inline-block;
    }
    .maintenance-container * { pointer-events: none; }
  </style>
  <script nonce="<%= cspNonce %>">
    document.addEventListener('contextmenu', e => e.preventDefault());
    document.addEventListener('keydown', e => {
      if (e.key === 'F12' || (e.ctrlKey && e.shiftKey && (e.key === 'I' || e.key === 'J' || e.key === 'C')) || (e.ctrlKey && e.key === 'u')) {
        e.preventDefault();
      }
    });

    (function enforceMaintenanceIntegrity() {
      const checkInterval = setInterval(async () => {
        try {
          const res = await fetch('/api/maintenance/status', { credentials: 'include' });
          if (res.ok) {
            const data = await res.json();
            if (data.active) return;
          }
          clearInterval(checkInterval);
          window.location.reload();
        } catch (e) {
        }
      }, 15000);

      const observer = new MutationObserver(() => {
        if (!document.querySelector('.maintenance-container')) {
          window.location.reload();
        }
      });
      observer.observe(document.body, { childList: true, subtree: true });
    })();
  </script>
</head>
<body>
  <div class="maintenance-container">
    <div class="maintenance-icon">
      <i class="fa-solid fa-wrench"></i>
    </div>
    <h1 class="maintenance-title">Under Maintenance</h1>
    <p class="maintenance-message">
      The panel is currently undergoing scheduled maintenance. We're working on improvements
      and will be back shortly. Thank you for your patience.
    </p>
    <% if (typeof reason !== 'undefined' && reason) { %>
      <div class="maintenance-reason">
        <i class="fa-solid fa-circle-info"></i>
        <span><%= reason %></span>
      </div>
    <% } %>
    <div class="maintenance-divider"></div>
    <div class="maintenance-footer">
      <span class="maintenance-dot"></span>
      <span>Maintenance in progress</span>
    </div>
  </div>
</body>
</html>
