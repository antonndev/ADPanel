          </div>
        </div>
        <button class="activity-close" id="subdomainCreateClose" title="Close (Esc)">
          <span class="activity-close-icon"><i class="fa-solid fa-xmark"></i></span>
        </button>
      </div>

      <div class="activity-body">
        <div class="backup-create-body">
          <div class="backup-create-field">
            <label for="subdomainInput">Domain</label>
            <input type="text" id="subdomainInput" placeholder="e.g. play.example.com" maxlength="255" />
          </div>
          <div class="backup-create-info">
            <i class="fa-solid fa-info-circle"></i>
            <span>Enter the full domain you want to link. Using a subdomain pointing to this node's IP is
              recommended.</span>
          </div>
          <div class="backup-create-field" id="subdomainVerificationResult" style="display:none; margin-top:12px;">
          </div>
        </div>
      </div>

      <div class="backup-create-footer">
        <button class="backup-create-cancel" id="subdomainCreateCancel">Cancel</button>
        <button class="backup-create-confirm" id="subdomainVerifyBtn">
          <i class="fa-solid fa-check" style="color: white;"></i>
          <span style="color: white;">Verify & Add</span>
        </button>
      </div>
    </div>
  </div>

  <div id="reinstallModal" class="activity-modal" aria-hidden="true">
    <div class="activity-glass-layer activity-glass-layer-1"></div>
    <div class="activity-glass-layer activity-glass-layer-2"></div>
    <div class="activity-glass-layer activity-glass-layer-3"></div>
    <div class="reinstall-panel" role="dialog" aria-modal="true" aria-labelledby="reinstallModalTitle">
      <div class="activity-inner-glow"></div>
      <div class="activity-header">
        <div class="activity-header-left">
          <div class="activity-icon-wrap">
            <div class="activity-icon-pulse"></div>
            <div class="activity-icon reinstall-icon-accent"><i class="fa-solid fa-rotate"></i></div>
          </div>
          <div class="activity-header-text">
            <div class="activity-title" id="reinstallModalTitle">Reinstall Server</div>
            <div class="activity-subtitle"><span class="activity-server-name">
                <%= displayName %>
              </span></div>
          </div>
        </div>
        <button class="activity-close" id="reinstallModalClose" title="Close (Esc)">
          <span class="activity-close-icon"><i class="fa-solid fa-xmark"></i></span>
        </button>
      </div>

      <div class="reinstall-body">
        <div class="reinstall-content" id="reinstallDefaultView">
          <div class="reinstall-warning-card">
            <div class="reinstall-warning-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div class="reinstall-warning-text">
              <div class="reinstall-warning-title">This will wipe your server clean</div>
              <div class="reinstall-warning-desc">Every file on this server will be permanently deleted and the server
                will be set up from scratch. Backups will not be affected, so make sure you've saved anything important
                before proceeding.</div>
            </div>
          </div>
          <div class="reinstall-info-cards">
            <div class="reinstall-info-card">
              <div class="reinstall-info-icon"><i class="fa-solid fa-trash-can"></i></div>
              <div class="reinstall-info-label">All server files removed</div>
            </div>
            <div class="reinstall-info-card">
              <div class="reinstall-info-icon"><i class="fa-solid fa-box-archive"></i></div>
              <div class="reinstall-info-label">Backups stay untouched</div>
            </div>
            <div class="reinstall-info-card">
              <div class="reinstall-info-icon"><i class="fa-solid fa-arrows-rotate"></i></div>
              <div class="reinstall-info-label">Fresh deployment with current template</div>
            </div>
          </div>
          <div class="reinstall-actions">
            <button class="reinstall-cancel-btn" id="reinstallCancelBtn">Cancel</button>
            <button class="reinstall-confirm-btn" id="reinstallConfirmBtn"><i class="fa-solid fa-rotate"></i> Reinstall
              Server</button>
          </div>
        </div>

        <div class="reinstall-content reinstall-confirm-view" id="reinstallConfirmView" style="display:none;">
          <div class="reinstall-confirm-icon-wrap">
            <div class="reinstall-confirm-big-icon"><i class="fa-solid fa-exclamation"></i></div>
          </div>
          <div class="reinstall-confirm-title">Are you absolutely sure?</div>
          <div class="reinstall-confirm-desc">This action cannot be undone. All server data will be erased and the
            server will be freshly deployed.</div>
          <div class="reinstall-confirm-actions">
            <button class="reinstall-cancel-btn" id="reinstallConfirmNo">No, go back</button>
            <button class="reinstall-danger-btn" id="reinstallConfirmYes"><i class="fa-solid fa-check"></i> Yes,
              reinstall now</button>
          </div>
        </div>

        <div class="reinstall-content reinstall-progress-view" id="reinstallProgressView" style="display:none;">
          <div class="reinstall-progress-spinner">
            <div class="reinstall-spinner"></div>
          </div>
          <div class="reinstall-progress-title" id="reinstallProgressTitle">Reinstalling server...</div>
          <div class="reinstall-progress-desc" id="reinstallProgressDesc">Removing old files and setting up a fresh
            deployment. This may take a moment.</div>
        </div>

        <div class="reinstall-content reinstall-success-view" id="reinstallSuccessView" style="display:none;">
          <div class="reinstall-success-icon-wrap">
            <div class="reinstall-success-big-icon"><i class="fa-solid fa-check"></i></div>
          </div>
          <div class="reinstall-success-title">Server reinstalled successfully</div>
          <div class="reinstall-success-desc">Your server has been wiped and freshly deployed. You can start it whenever
            you're ready.</div>
          <div class="reinstall-success-actions">
            <button class="reinstall-done-btn" id="reinstallDoneBtn"><i class="fa-solid fa-check"></i> Done</button>
          </div>
        </div>

        <div class="reinstall-content reinstall-error-view" id="reinstallErrorView" style="display:none;">
          <div class="reinstall-error-icon-wrap">
            <div class="reinstall-error-big-icon"><i class="fa-solid fa-xmark"></i></div>
          </div>
          <div class="reinstall-error-title">Reinstall failed</div>
          <div class="reinstall-error-desc" id="reinstallErrorDesc">Something went wrong during the reinstall process.
            Please try again or contact an administrator.</div>
          <div class="reinstall-error-actions">
            <button class="reinstall-cancel-btn" id="reinstallErrorClose">Close</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="clearConsoleModal" class="clear-console-modal" style="display: none;" aria-hidden="true">
    <div class="clear-console-glass-layer"></div>
    <div class="clear-console-content">
      <h3 class="clear-console-title">Clear Console</h3>
      <p class="clear-console-desc">Are you sure? This action cannot be undone.</p>
      <div class="clear-console-toggle-wrapper" id="clearConsoleToggleWrapper">
        <span class="clear-console-label-text">Do not ask me again</span>
        <label class="switch" onclick="event.stopPropagation()">
          <input type="checkbox" id="clearConsoleNoAsk">
          <span class="slider"></span>
        </label>
      </div>
      <div class="clear-console-actions">
        <button id="clearConsoleCancel" class="btn-cancel">Cancel</button>
        <button id="clearConsoleConfirm" class="btn-clear">Clear Console</button>
      </div>
    </div>
  </div>

</body>

</html>
