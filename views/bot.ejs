  <script nonce="<%= cspNonce %>" data-cfasync="false"
    src="https://cdn.jsdelivr.net/npm/ace-builds@1.36.5/src-min-noconflict/mode-css.js"></script>
  <script nonce="<%= cspNonce %>" data-cfasync="false"
    src="https://cdn.jsdelivr.net/npm/ace-builds@1.36.5/src-min-noconflict/mode-java.js"></script>
  <script nonce="<%= cspNonce %>" data-cfasync="false"
    src="https://cdn.jsdelivr.net/npm/ace-builds@1.36.5/src-min-noconflict/mode-text.js"></script>



  <script nonce="<%= cspNonce %>" data-cfasync="false" src="/js/bot.js?v=<%= Date.now() %>" defer></script>
  <script nonce="<%= cspNonce %>" data-cfasync="false"
    src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.0/min/vs/loader.min.js"></script>

  <script nonce="<%= cspNonce %>" data-cfasync="false">
    (function () {
      const CHRISTMAS_IMG = '/images/ADPanel-christmas.png';
      function isChristmasPeriod() {
        const now = new Date();
        const month = now.getMonth();
        const day = now.getDate();
        return month === 11 && day >= 25 && day <= 28;
      }
      function applyChristmasTheme() {
        if (!isChristmasPeriod()) return;
        const favicon = document.getElementById('favicon') || document.querySelector('link[rel="icon"]');
        if (favicon) favicon.href = CHRISTMAS_IMG;
        document.querySelectorAll('img').forEach(img => {
          if (img.src && (img.src.includes('ADPanel-dark.webp') || img.src.includes('i.imgur.com/k5agjYf'))) {
            img.src = CHRISTMAS_IMG;
          }
        });
      }
      document.addEventListener('DOMContentLoaded', applyChristmasTheme);
    })();
  </script>

  <link rel="stylesheet" href="/css/bot.css?v=<%= Date.now() %>">
  <style nonce="<%= cspNonce %>">
    *,
    *::before,
    *::after {
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      user-select: none;
    }

    #console,
    #console *,
    .ai-chat-messages,
    .ai-chat-messages *,
    .ai-message,
    .ai-message *,
    .ai-model-selector,
    .ai-model-selector *,
    input,
    textarea {
      -webkit-user-select: text;
      -moz-user-select: text;
      -ms-user-select: text;
      user-select: text;
    }

    #console {
      cursor: text;
    }

    img,
    video,
    canvas {
      -webkit-user-drag: none;
      user-drag: none;
    }
  </style>
  <script nonce="<%= cspNonce %>">
    function isInteractive(el) {
      if (!el) return false;
      if (el.nodeType === 3) el = el.parentNode;
      if (!el.tagName) return false;
      const tag = el.tagName.toUpperCase();
      return tag === 'INPUT' || tag === 'TEXTAREA' || !!el.closest('#console, .ai-chat-messages, .ai-message, .ai-model-selector');
    }

    document.addEventListener('contextmenu', e => {
      if (!isInteractive(e.target)) e.preventDefault();
    });
    document.addEventListener('dragstart', e => {
      if (!isInteractive(e.target)) e.preventDefault();
    });
    document.addEventListener('selectstart', e => {
      if (!isInteractive(e.target)) e.preventDefault();
    });
    document.addEventListener('copy', e => {
      const selection = window.getSelection().toString();
      if (selection.length === 0 && !isInteractive(e.target)) e.preventDefault();
    });
    document.addEventListener('cut', e => {
      const tag = (e.target && e.target.tagName) ? e.target.tagName.toUpperCase() : '';
      if (tag !== 'INPUT' && tag !== 'TEXTAREA') e.preventDefault();
    });

    document.addEventListener('keydown', e => {
      const tag = (e.target && e.target.tagName) ? e.target.tagName.toUpperCase() : '';
      const isInput = tag === 'INPUT' || tag === 'TEXTAREA';

      if (e.ctrlKey || e.metaKey) {
        if (['c', 'C'].includes(e.key)) {
          return;
        }

        if (['a', 'A'].includes(e.key)) {
          if (isInput) return;

          e.preventDefault();
          const consoleEl = document.getElementById('console');
          if (consoleEl) {
            const range = document.createRange();
            range.selectNodeContents(consoleEl);
            const sel = window.getSelection();
            sel.removeAllRanges();
            sel.addRange(range);
          }
          return;
        }

        if (['s', 'S', 'u', 'U'].includes(e.key)) {
          e.preventDefault();
        }
      }
    });
  </script>
  <style nonce="<%= cspNonce %>">
    body {
      background-color: #0b0f14;
      color: #e6eef8;
      margin: 0 !important;
      padding: 0 !important;
      overflow-x: hidden;
    }

    #mobile-block-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: #000;
      z-index: 999999;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 20px;
      white-space: normal;
    }

    #mobile-block-overlay h2 {
      width: 100%;
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.4;
      font-size: clamp(18px, 5vw, 24px);
      padding: 0 10px;
      word-wrap: break-word;
    }

    @media (max-width: 767px) and (orientation: portrait) {
      #mobile-block-overlay {
        display: flex !important;
      }
    }
  </style>
  <style nonce="<%= cspNonce %>">
    .sidebar-shell {
      transition:
        width 0.42s cubic-bezier(0.22, 1, 0.36, 1),
        opacity 0.2s ease,
        background-color 0.42s cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 0.42s cubic-bezier(0.22, 1, 0.36, 1) !important;
      will-change: width, background-color, box-shadow;
    }

    .sidebar-shell.open:hover {
      box-shadow:
        0 18px 44px rgba(0, 0, 0, 0.34),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
      background-color: rgba(255, 255, 255, 0.062);
    }

    .sidebar-shell.open .sidebar-item,
    .sidebar-shell.open .profile-card {
      transition:
        background 0.2s ease,
        transform 0.2s ease,
        color 0.2s ease,
        padding 0.38s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .sidebar-shell.open .sidebar-item .label,
    .sidebar-shell.open .profile-meta {
      transition:
        max-width 0.36s cubic-bezier(0.22, 1, 0.36, 1),
        opacity 0.26s ease,
        transform 0.36s cubic-bezier(0.22, 1, 0.36, 1);
      transition-delay: 0s;
    }

    .sidebar-shell.open:hover .sidebar-item .label,
    .sidebar-shell.open:hover .profile-meta {
      transition-delay: 0.08s;
    }

    .sidebar-shell.open:not(:hover) .sidebar-item .label,
    .sidebar-shell.open:not(:hover) .profile-meta {
      transition-delay: 0s;
    }

    #cmdInput,
    #cmdInput:hover,
    #cmdInput:focus,
    #cmdInput:focus-visible,
    #cmdInput:active {
      outline: none !important;
      border: none !important;
      box-shadow: none !important;
      transition: none !important;
    }
  </style>
</head>

<body>
  <div id="mobile-block-overlay">
    <h2 style="color: white; font-weight: 700; font-size: 24px;">If you're on mobile, turn on your Desktop Mode or use
      Landscape to work</h2>
  </div>
  <svg xmlns="http://www.w3.org/2000/svg" style="display:none;">
    <defs>
      <filter id="glass-distortion" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.008 0.008" numOctaves="2" seed="92" result="noise" />
        <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
        <feDisplacementMap in="SourceGraphic" in2="blurred" scale="77" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>
  <div id="offlineOverlay" class="notfound-modal" aria-hidden="true">
    <div class="notfound-glass-layer notfound-glass-layer-1"></div>
    <div class="notfound-glass-layer notfound-glass-layer-2"></div>
    <div class="notfound-panel" role="dialog" aria-modal="true">
      <div class="notfound-content">
        <div class="notfound-robot">
          <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/adpanel-dark.webp" alt="ADPanel"
            class="notfound-robot-img" draggable="false" />
        </div>
        <div class="notfound-text">
          <div class="notfound-code">404</div>
          <div class="notfound-title">Page Not Found</div>
          <div class="notfound-desc offline-text">The server you're looking for doesn't exist or has been removed.</div>
        </div>
        <div class="notfound-actions">
          <a href="/" class="notfound-btn-primary">
            <i class="fa-solid fa-house"></i>
            <span>Back to Dashboard</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle quick actions" type="button"><i
      class="fa-solid fa-grip"></i></button>
  <aside class="sidebar-shell open" id="floatingSidebar" aria-label="Quick navigation">
    <div class="sidebar-top">
      <a href="/#account" class="sidebar-item active"
        style="text-decoration: none; font-size: 13.33px; box-sizing: border-box;">
        <span class="icon"><i class="fa-solid fa-user-gear"></i></span>
        <span class="label">Account</span>
      </a>
    </div>
    <div class="sidebar-middle">
      <a class="sidebar-item" href="/"
        style="text-decoration: none; color: inherit; font-size: 13.33px; box-sizing: border-box;">
        <span class="icon"><i class="fa-solid fa-house"></i></span>
        <span class="label">Overview</span>
      </a>
      <button class="sidebar-item" type="button" id="resourceStatsBtn" data-action="open-resource-stats">
        <span class="icon"><i class="fa-solid fa-chart-pie"></i></span>
        <span class="label">Resource statistics</span>
      </button>

      <a class="sidebar-item" href="/#servers"
        style="text-decoration: none; color: inherit; font-size: 13.33px; box-sizing: border-box;">
        <span class="icon"><i class="fa-solid fa-server"></i></span>
        <span class="label">My servers</span>
      </a>
      <button class="sidebar-item" type="button" id="subdomainsSidebarBtn" data-action="open-subdomains">
        <span class="icon"><i class="fa-solid fa-globe"></i></span>
        <span class="label">Subdomains</span>
      </button>
      <% if (user && user.admin) { %>
        <a href="/settings" class="sidebar-item"
          style="text-decoration: none; color: inherit; font-size: 13.33px; box-sizing: border-box;">
          <span class="icon"><i class="fa-solid fa-gear"></i></span>
          <span class="label">Panel Settings</span>
        </a>
        <% } %>
    </div>
    <div class="sidebar-bottom">
      <button class="profile-card" id="profileCard" type="button">
        <div class="icon">
          <img src="<%= avatarUrl %>" alt="Avatar"
            style="width: 100%; height: 100%; border-radius: 999px; object-fit: cover;" draggable="false">
        </div>
        <div class="profile-meta">
          <span id="profileEmail">—</span>
          <div class="profile-status"><span class="status-dot"></span><span id="profileStatusLabel">Available</span>
          </div>
        </div>
      </button>
      <div class="status-popover" id="statusPopover" role="dialog" aria-modal="true" aria-label="Update status">
        <div>
          <label for="statusInput">Custom status</label>
          <input id="statusInput" class="statusinputs" type="text" placeholder="In a flow..." maxlength="80" />
        </div>
        <div>
          <label for="statusDuration">Clear after</label>
          <div class="custom-select-wrapper" style="position:relative;width:100%">
            <select id="statusDuration" style="display:none">
              <option value="86400000">1 day</option>
              <option value="259200000">3 days</option>
              <option value="604800000">1 week</option>
              <option value="2592000000">1 month</option>
              <option value="never">Never</option>
            </select>
            <div class="custom-select" id="customStatusDuration" tabindex="0">
              <span class="current">1 day</span>
              <div class="arrow"></div>
            </div>
            <div class="custom-options" id="customStatusOptions">
              <div class="option selected" data-value="86400000">1 day</div>
              <div class="option" data-value="259200000">3 days</div>
              <div class="option" data-value="604800000">1 week</div>
              <div class="option" data-value="2592000000">1 month</div>
              <div class="option" data-value="never">Never</div>
            </div>
          </div>
        </div>
        <div class="status-actions">
          <button type="button" id="cancelStatus">Cancel</button>
          <button type="button" class="save" id="saveStatus">Save</button>
        </div>
      </div>
    </div>
  </aside>
  <div class="app-wrap">
    <div class="topbar">
      <div class="brands"></div>

      <div class="top-actions">
        <button class="icon-btn" id="filesBtn" data-action="open-files"><i class="fa-solid fa-folder-open"></i>
          Files</button>
        <button class="icon-btn" id="backupsBtn" data-action="open-backups"><i class="fa-solid fa-box-archive"></i>
          Backups</button>

        <button class="icon-btn" id="storeBtn" data-action="open-store"><i class="fa-solid fa-store"></i> Store</button>
        <button class="icon-btn" id="activityBtn" data-action="open-activity"><i
            class="fa-solid fa-clock-rotate-left"></i> Activity</button>
        <button class="icon-btn" id="schedulerBtn" data-action="open-scheduler"><i
            class="fa-solid fa-calendar-days"></i> Scheduler</button>
        <button class="icon-btn" id="aiHelpBtn" data-action="open-ai-help">
          <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/adpanel-dark.webp" alt="ADPanel Agent" width="20px"
            height="21px" /> ADPanel Agent</button>
        <button class="icon-btn" id="infoBtn" data-action="open-info"><i class="fa-solid fa-circle-info"></i>
          Information</button>
        <button class="icon-btn" id="runBtn" data-action="run" title="Run selected"><i class="fa-solid fa-play"></i>
          Run</button>
        <button class="icon-btn" id="subdomainsBtn" data-action="open-subdomains"><i class="fa-solid fa-globe"></i>
          Subdomains</button>
        <button class="icon-btn" id="stopBtn" data-action="stop" title="Stop process"><i class="fa-solid fa-stop"></i>
          Stop</button>
        <button class="icon-btn reinstall-topbar-btn" id="reinstallBtn" data-action="open-reinstall"
          title="Reinstall server"><i class="fa-solid fa-rotate"></i>
          Reinstall</button>
      </div>
    </div>

    <div class="main-stage" style="margin-top:2px">
      <div class="console-panel" role="main" aria-label="Console panel"
        style="position: absolute; display: flex; justify-content: center; align-items: center; margin-left: 20px;">
        <div class="console-window"
          style="height: 500px; backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);">
          <div class="brandss"
            style="display:flex;align-items:center; gap:10px; position:absolute; top:-60px; left:-40px;">
            <a href="/"><img src="https://i.imgur.com/k5agjYf.png" width="50" height="30"></a>
            <a href="/"
              style="position: absolute;font-size:30px;font-weight:bold;color:white;text-decoration:none; margin-top: -5px; margin-left: 55px;">Panel</a>
          </div>
          <div class="window-header">
            <div style="display:flex;align-items:center;gap:8px">
              <span class="dot" style="background:#ff5f56;cursor:pointer" data-action="stop"></span>
              <span class="dot" style="background:#ffbd2e;cursor:pointer" data-action="stop"></span>
              <span class="dot" style="background:#27c93f;cursor:pointer" data-action="run"></span>
              <div style="margin-left:6px;color:var(--muted);font-size:13px">Console — <span
                  style="color:#fff;font-weight:700">
                  <%= displayName %>
                </span></div>
            </div>
            <div class="window-controls">
              <div style="color:var(--muted);font-size:13px">Status: <span id="statusLabel">idle</span></div>
            </div>
          </div>

          <div class="controls">
            <button class="run-button" id="miniRunBtn" data-action="run" title="Run"><i class="fa-solid fa-play"
                style="transform:rotate(90deg)"></i></button>
            <button class="stop-button" id="miniStopBtn" data-action="stop" title="Stop"><i
                class="fa-solid fa-stop"></i></button>
            <button class="stop-button kill-button" id="miniKillBtn" data-action="kill" title="Kill container"><i
                class="fa-solid fa-power-off"></i></button>
            <div style="flex:1"></div>
          </div>

          <pre id="console" aria-live="polite"></pre>

          <div class="cmd-row" id="cmdRow" style="margin-top: 4px;">
            <input id="cmdInput" class="command" type="text" placeholder="Type a command and press Enter" />
            <button class="icon-btn" id="sendBtn" data-action="send" title="Send">Send</button>
            <button class="icon-btn" id="clearBtn" data-action="clear" title="Clear">Clear</button>
          </div>
        </div>
      </div>
    </div>
  </div>


  <div id="infoModal" class="info-modal" aria-hidden="true">
    <div class="info-glass-layer info-glass-layer-1"></div>
    <div class="info-glass-layer info-glass-layer-2"></div>
    <div class="info-glass-layer info-glass-layer-3"></div>
    <div class="info-panel" role="dialog" aria-modal="true" aria-labelledby="infoModalTitle">
      <div class="info-inner-glow"></div>
      <div class="info-header">
        <div class="info-header-left">
          <div class="info-icon-wrap">
            <div class="info-icon-pulse"></div>
            <div class="info-icon"><i class="fa-solid fa-circle-info"></i></div>
          </div>
          <div class="info-header-text">
            <div class="info-title" id="infoModalTitle">Server Information</div>
            <div class="info-subtitle"><span class="info-server-name">
                <%= displayName %>
              </span></div>
          </div>
        </div>
        <button class="info-close" id="infoModalClose" title="Close (Esc)">
          <span class="info-close-icon"><i class="fa-solid fa-xmark"></i></span>
        </button>
      </div>

      <div class="info-body">
        <div class="info-section">
          <div class="info-section-title">
            <i class="fa-solid fa-server"></i>
            <span>Connection Details</span>
          </div>
          <div class="info-grid">
            <div class="info-card">
              <div class="info-card-icon"><i class="fa-solid fa-network-wired"></i></div>
              <div class="info-card-content">
                <div class="info-card-label">IP Address</div>
                <div class="info-card-value" id="infoIp">—</div>
              </div>
            </div>
            <div class="info-card">
              <div class="info-card-icon"><i class="fa-solid fa-plug"></i></div>
              <div class="info-card-content">
                <div class="info-card-label">Port</div>
                <div class="info-card-value" id="infoPort">—</div>
              </div>
            </div>
          </div>
          <div class="info-address-row">
            <div class="info-address-label">Connection Address</div>
            <div class="info-address-wrap">
              <input id="infoAddress" class="info-address-input" type="text" readonly value="" />
              <button id="copyAddressBtn" class="info-copy-btn" title="Copy to clipboard">
                <i class="fa-solid fa-copy"></i>
              </button>
            </div>
            <div class="info-address-hint">Share this address to connect to your server</div>
          </div>
        </div>

        <div class="info-section info-sftp-section" id="infoSftpSection" style="display:none;">
          <div class="info-section-title" style="display:none;">
            <i class="fa-solid fa-folder-tree" style="display:none;"></i>
            <span style="display:none;">SFTP Credentials</span>
            <span class="info-sftp-badge" style="display:none;">Secure</span>
          </div>
          <div class="info-sftp-notice" style="display:none;">
            <i class="fa-solid fa-shield-halved" style="display:none;"></i>
            <span style="display:none;">Access restricted to your server folder only</span>
          </div>
          <div class="info-grid" style="display:none;">
            <div class="info-card" style="display:none;">
              <div class="info-card-icon" style="display:none;"><i class="fa-solid fa-globe"></i></div>
              <div class="info-card-content" style="display:none;">
                <div class="info-card-label" style="display:none;">SFTP Host</div>
                <div class="info-card-value info-sftp-value" id="infoSftpHost" style="display:none;">—</div>
              </div>
              <button class="info-card-copy" data-copy="infoSftpHost" title="Copy" style="display:none;"><i
                  class="fa-solid fa-copy"></i></button>
            </div>
            <div class="info-card" style="display:none;">
