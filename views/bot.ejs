            </div>

            <div class="scheduler-form-section">
              <label class="scheduler-label">Schedule Type</label>
              <div class="scheduler-schedule-options">
                <button class="scheduler-schedule-option active" data-schedule="once">
                  <i class="fa-solid fa-clock"></i>
                  <span>One Time</span>
                </button>
                <button class="scheduler-schedule-option" data-schedule="recurring">
                  <i class="fa-solid fa-repeat"></i>
                  <span>Recurring</span>
                </button>
              </div>
            </div>

            <div class="scheduler-form-section" id="schedulerOnceSection">
              <label class="scheduler-label">Run At</label>
              <div class="scheduler-datetime-row">
                <input type="date" class="scheduler-input" id="schedulerDate">
                <input type="time" class="scheduler-input" id="schedulerTime" value="00:00">
              </div>
            </div>

            <div class="scheduler-form-section hidden" id="schedulerRecurringSection">
              <label class="scheduler-label">Repeat</label>
              <div class="scheduler-recurring-options">
                <select class="scheduler-select" id="schedulerRecurringType">
                  <option value="seconds">Every X Seconds</option>
                  <option value="minutes">Every X Minutes</option>
                  <option value="hourly">Every X Hours</option>
                  <option value="daily">Daily at Time</option>
                  <option value="weekly">Weekly on Day</option>
                </select>
              </div>

              <div class="scheduler-recurring-config" id="schedulerSecondsConfig">
                <label class="scheduler-label-small">Every</label>
                <select class="scheduler-select scheduler-select-small" id="schedulerSecondsInterval">
                  <option value="10">10 seconds</option>
                  <option value="15">15 seconds</option>
                  <option value="30" selected>30 seconds</option>
                  <option value="45">45 seconds</option>
                </select>
              </div>

              <div class="scheduler-recurring-config hidden" id="schedulerMinutesConfig">
                <label class="scheduler-label-small">Every</label>
                <select class="scheduler-select scheduler-select-small" id="schedulerMinutesInterval">
                  <option value="1">1 minute</option>
                  <option value="2">2 minutes</option>
                  <option value="5" selected>5 minutes</option>
                  <option value="10">10 minutes</option>
                  <option value="15">15 minutes</option>
                  <option value="20">20 minutes</option>
                  <option value="30">30 minutes</option>
                  <option value="45">45 minutes</option>
                </select>
              </div>

              <div class="scheduler-recurring-config hidden" id="schedulerHourlyConfig">
                <label class="scheduler-label-small">Every</label>
                <select class="scheduler-select scheduler-select-small" id="schedulerHourlyInterval">
                  <option value="1">1 hour</option>
                  <option value="2">2 hours</option>
                  <option value="3">3 hours</option>
                  <option value="4">4 hours</option>
                  <option value="6">6 hours</option>
                  <option value="8">8 hours</option>
                  <option value="12">12 hours</option>
                  <option value="24">24 hours</option>
                </select>
              </div>

              <div class="scheduler-recurring-config hidden" id="schedulerDailyConfig">
                <label class="scheduler-label-small">At</label>
                <input type="time" class="scheduler-input" id="schedulerDailyTime" value="00:00">
              </div>

              <div class="scheduler-recurring-config hidden" id="schedulerWeeklyConfig">
                <label class="scheduler-label-small">On</label>
                <select class="scheduler-select" id="schedulerWeeklyDay">
                  <option value="0">Sunday</option>
                  <option value="1">Monday</option>
                  <option value="2">Tuesday</option>
                  <option value="3">Wednesday</option>
                  <option value="4">Thursday</option>
                  <option value="5">Friday</option>
                  <option value="6">Saturday</option>
                </select>
                <label class="scheduler-label-small">at</label>
                <input type="time" class="scheduler-input" id="schedulerWeeklyTime" value="00:00">
              </div>
            </div>

            <div class="scheduler-or-divider">
              <span>ACTION</span>
