<!DOCTYPE html>
<head>
  <title>Forgot password?</title>
  <link id="favicon" rel="icon" type="image/webp" href="<%= (branding && branding.faviconUrl) ? branding.faviconUrl : '/auth-assets/favicon' %>" />
  <style nonce="<%= cspNonce %>">
    strong {
      background-color: gray;
      color: white;
    }
  </style>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
  <script nonce="<%= cspNonce %>">
    (function () {
      const CHRISTMAS_IMG = '/auth-assets/christmas-logo';
      function isChristmasPeriod() {
        const now = new Date();
        const month = now.getMonth();
        const day = now.getDate();
        return month === 11 && day >= 25 && day <= 28;
      }
      function applyChristmasTheme() {
        if (!isChristmasPeriod()) return;
        const favicon = document.getElementById('favicon') || document.querySelector('link[rel="icon"]');
        if (favicon) favicon.href = CHRISTMAS_IMG;
        document.querySelectorAll('img').forEach(img => {
          if (img.src && (img.src.includes('ADPanel-dark.webp') || img.src.includes('i.imgur.com/k5agjYf'))) {
            img.src = CHRISTMAS_IMG;
          }
        });
      }
      document.addEventListener('DOMContentLoaded', applyChristmasTheme);
    })();
  </script>
  <style nonce="<%= cspNonce %>">
    *,
    *::before,
    *::after {
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      user-select: none;
    }

    img,
    video,
    canvas {
      -webkit-user-drag: none;
      user-drag: none;
    }
  </style>
  <script nonce="<%= cspNonce %>">
    document.addEventListener('contextmenu', e => e.preventDefault());
    document.addEventListener('dragstart', e => e.preventDefault());
    document.addEventListener('selectstart', e => e.preventDefault());
    document.addEventListener('copy', e => e.preventDefault());
    document.addEventListener('cut', e => e.preventDefault());
    document.addEventListener('keydown', e => {
      if ((e.ctrlKey || e.metaKey) && ['c', 'C', 'a', 'A', 's', 'S', 'u', 'U'].includes(e.key)) e.preventDefault();
    });
  </script>
</head>

<body>
  <html>
  <p>
    [Dashboard] Due to security reasons you can only reset your password
    directly from the terminal using the command
    <strong>bash initialize.sh</strong> from the ADPanel directory or switching to an admin account and resetting it for the specific user from Accounts settings category.
  </p>
  <p>This panel version doesn't support change password feature directly from normal user UI.</p>

  </html>
</body>
