    <div class="enterprise-modal template-enterprise-modal" id="createTemplateModal">
      <div class="enterprise-modal-header">
        <div class="enterprise-modal-icon template-icon">
          <i class="fa-solid fa-file-code"></i>
        </div>
        <div class="enterprise-modal-titles">
          <h3 class="enterprise-modal-title" id="createTemplateModalTitle">New Template</h3>
          <p class="enterprise-modal-subtitle" id="createTemplateModalSubtitle">Set up a reusable Docker template.</p>
        </div>
        <button class="enterprise-modal-close" id="createTemplateClose" aria-label="Close">
