<!doctype html>
<html lang="en" data-theme="dark">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  
  <style nonce="<%= cspNonce %>">
    html:not([data-theme="dark"]) body{background:#f3f4f6;color:#0f172a}
    html[data-theme="dark"] body{background:#282c34;color:#e6eef8}
  </style>

  <script nonce="<%= cspNonce %>">
    (function(){
      try{
        var bg=localStorage.getItem('dashboardBg');
        if(bg){
          var data=JSON.parse(bg);
          if(data.type==='color'&&data.value){
            document.documentElement.style.setProperty('--bg-main',data.value);
          }else if(data.type==='image'&&data.value){
            document.documentElement.style.setProperty('--bg-main','url('+data.value+')');
          }
        }
      }catch(e){}
    })();
  </script>

  <link rel="stylesheet" href="settings.css?v=18">
  <title><%= (branding && branding.appName) ? branding.appName : 'ADPanel' %> Settings</title>
  <link id="favicon" rel="icon" type="image/webp" sizes="16x16"
    href="<%= (branding && branding.faviconUrl) ? branding.faviconUrl : '/auth-assets/favicon' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
  <link id="faLink" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha384-nRgPTkuX86pH8yjPJUAFuASXQSSl2/bBUiNV47vSYpKFxHJhbcrGnmlYpYJMeD7a" crossorigin="anonymous" referrerpolicy="no-referrer" media="print">
  <link id="gfLink" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Space+Grotesk:wght@400;600&display=swap" rel="stylesheet" media="print">


  <script nonce="<%= cspNonce %>">
    (function () {
      const CHRISTMAS_IMG = '/images/ADPanel-christmas.png';
      function isChristmasPeriod() {
        const now = new Date();
        const month = now.getMonth();
        const day = now.getDate();
        return month === 11 && day >= 25 && day <= 28;
      }
      function applyChristmasTheme() {
        if (!isChristmasPeriod()) return;
        const favicon = document.getElementById('favicon') || document.querySelector('link[rel="icon"]');
        if (favicon) favicon.href = CHRISTMAS_IMG;
        document.querySelectorAll('img').forEach(img => {
          if (img.src && (img.src.includes('ADPanel-dark.webp') || img.src.includes('i.imgur.com/k5agjYf'))) {
            img.src = CHRISTMAS_IMG;
          }
        });
      }
      document.addEventListener('DOMContentLoaded', applyChristmasTheme);
    })();
  </script>


  <script nonce="<%= cspNonce %>" data-cfasync="false" src="/js/settings.js?v=13" defer></script>
  <script nonce="<%= cspNonce %>">
    (function(){
      function enableLink(id){var l=document.getElementById(id);if(l)l.media='all';}
      ['faLink','gfLink'].forEach(function(id){
        var l=document.getElementById(id);
        if(!l)return;
        if(l.sheet){enableLink(id);}else{l.addEventListener('load',function(){enableLink(id);});}
      });
    })();
  </script>
</head>

<body>

  <div class="closeEscFixed" id="closeEscFixed" title="Go Back">
    <div class="closeEscFixed-inner">
      <i class="fa-solid fa-xmark"></i>
      <small>ESC</small>
    </div>
  </div>

  <div class="app">
    <aside class="sidebar" aria-label="Sidebar">
      <div class="brand">
        <div class="logo"><i class="fa-solid fa-cog"></i></div>
        <div>
          <h1>Settings</h1>
          <p>Customize ADPanel.</p>
        </div>
      </div>

      <nav class="nav" id="sidebarNav">
        <button data-panel="preferences" class="active"><i class="fa-solid fa-cog"></i> Preferences</button>
        <button data-panel="customization"><i class="fa-solid fa-palette"></i> Customization</button>
        <button data-panel="account"><i class="fa-solid fa-user"></i> Account</button>
        <button data-panel="security"><i class="fa-solid fa-shield-halved"></i> Security</button>
        <% if (user && user.admin) { %>
        <button data-panel="sessions"><i class="fa-solid fa-window-restore"></i> Sessions</button>
        <% } %>
        <button data-panel="databases"><i class="fa-solid fa-database"></i> Databases</button>
        <button data-panel="nodes"><i class="fa-solid fa-diagram-project"></i> Nodes</button>
        <button data-panel="templates"><i class="fa-solid fa-file"></i> Templates</button>
        <button data-panel="servers"><i class="fa-solid fa-server"></i> Servers</button>
        <button data-panel="webhooks"><i class="fa-brands fa-discord"></i> Webhooks</button>
        <% if (user && user.admin) { %>
          <button data-panel="panelinfo"><i class="fa-solid fa-circle-info"></i> Panel Info</button>
          <% } %>
      </nav>

    </aside>

    <main>
      <section class="panel" aria-labelledby="settings-title">
        <h2 id="settings-title">Settings</h2>

        <div class="layout-inner">
          <div class="content-flex">
            <div class="content-area">
              <div id="preferences" class="panel-section active">
                <div class="panelinfo-header">
                  <div>
                    <div class="panelinfo-title">Preferences</div>
                    <div class="panelinfo-subtitle">Bring ADPanel to your style.</div>
                  </div>
                </div>

                <div class="panelinfo-content">
                  <div class="glass-card">
                    <div class="glass-card-inner">
                      <div class="glass-card-header">
                        <div class="glass-card-title"><i class="fa-regular fa-image"></i> <span>Background
                            Selection</span></div>
                        <div class="glass-card-subtitle">First, you need a unique look</div>
                      </div>

                      <div class="bg-section-grid">
                        <div class="bg-preview-wrapper">
                          <div class="bg-preview" id="bgPreview">
                            <div class="label">Main color</div>
                            <div class="bg-preview-text">
                              <div class="bg-hex-display" id="bgHex">#ffffff</div>
                              <div class="bg-preview-label">Preview area</div>
                            </div>
                          </div>
                        </div>

                        <div class="bg-controls-wrapper">
                          <div class="control-group">
                            <label>Main Theme Color</label>
                            <div class="color-picker-row">
                              <div class="color-dot" id="colorDot" style="background:#ffffff"></div>
                              <input type="color" id="colorPicker" value="#ffffff" title="Pick main color">
                              <input type="text" id="hexInput" value="#ffffff" class="glass-input"
                                aria-label="Hex input">
                              <button class="btn-glass" id="applyColorBtn"><i class="fa-solid fa-check"></i>
                                Apply</button>
                            </div>
                          </div>

                          <div class="control-group">
                            <label>Background Image</label>
                            <div class="upload-row">
                              <div class="btn-upload" id="uploadBtn" role="button" tabindex="0"><i
                                  class="fa-solid fa-upload"></i> Upload</div>
                              <input id="uploadFile" type="file" accept="image/*"
                                style="position:absolute;width:0;height:0;opacity:0;overflow:hidden">
                              <input type="text" id="urlInput" placeholder="Paste image URL" class="glass-input">
                              <button class="btn-glass" id="useUrlBtn">Use</button>
                            </div>
                          </div>
                        </div>
                      </div>

                      <div class="thumbs-section">
                        <div class="thumbs-title">Thumbnail Previews</div>
                        <div class="thumbs" id="thumbs"></div>
                      </div>

                      <div class="note">Note: background set here will be applied to the dashboard and main style
                        files.</div>
                    </div>
                  </div>

                  <div class="glass-card">
                    <div class="glass-card-inner">
                      <div class="glass-card-header">
                        <div class="background-title"><i class="fa-solid fa-floppy-disk"></i> <span>Saved
                            Background</span></div>
                      </div>
                      <div id="savedBg" class="saved-bg-value">None</div>
                    </div>
                  </div>
                </div>
              </div>

              <div id="customization" class="panel-section">
                <div class="customization-header">
                  <div>
                    <div class="customization-title">Customization</div>
                    <div class="customization-subtitle">Personalize your dashboard experience</div>
                  </div>
                </div>

                <% if (user && user.admin) { %>
                  <div class="customization-section">
                    <div class="customization-section-header">
                      <div class="customization-section-info">
                        <div class="customization-section-icon" style="background-color: none; background: none;">
                          <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/adpanel-dark.webp"
                            alt="Quick Actions" width="47px" height="47px">
                        </div>
                        <div>
                          <div class="customization-section-title">Quick Actions</div>
                          <div class="customization-section-desc">Configure buttons shown on the dashboard</div>
                        </div>
                      </div>
                    </div>

                    <div class="quick-actions-config">
                      <div class="qa-subgroup">
                        <div class="qa-subgroup-header">
                          <span class="qa-subgroup-title">For Admins</span>
                          <button class="btn btn-sm" id="addQuickActionBtn" title="Add admin action">
                            <i class="fa-solid fa-plus"></i> Add
                          </button>
                        </div>

                        <div class="quick-actions-list" id="quickActionsList"></div>

                        <div class="quick-actions-empty" id="quickActionsEmpty" style="display: none;">
                          <i class="fa-solid fa-layer-group"></i>
                          <p>No admin actions configured</p>
                        </div>
                        <div class="quick-actions-limit-note">
                          <i class="fa-solid fa-circle-info"></i>
                          <span id="quickActionsCount">0</span>/6 actions
                        </div>
                      </div>

                      <div class="qa-separator"></div>

                      <div class="qa-subgroup">
                        <div class="qa-subgroup-header">
                          <span class="qa-subgroup-title">For Normal Users</span>
                          <button class="btn btn-sm" id="addUserQuickActionBtn" title="Add user action">
                            <i class="fa-solid fa-plus"></i> Add
                          </button>
                        </div>

                        <div class="quick-actions-list" id="userQuickActionsList"></div>

                        <div class="quick-actions-empty" id="userQuickActionsEmpty" style="display: none;">
                          <i class="fa-solid fa-layer-group"></i>
                          <p>No user actions configured</p>
                        </div>
                        <div class="quick-actions-limit-note">
                          <i class="fa-solid fa-circle-info"></i>
                          <span id="userQuickActionsCount">0</span>/6 actions
                        </div>
                      </div>

                    </div>
                  </div>
                  <% } %>

                    <div class="customization-section">
                      <div class="customization-section-header">
                        <div class="customization-section-info">
                          <div class="customization-section-icon" style="background-color: none; background: none;">
                            <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/create-user.webp" alt="Branding"
                              width="47px" height="47px">
                          </div>
                          <div>
                            <div class="customization-section-title">Change name and logos</div>
                            <div class="customization-section-desc">Turn ADPanel into your brand</div>
                          </div>
                        </div>
                        <button class="btn" id="openBrandingBtn" title="Change branding">
                          <i class="fa-solid fa-pen"></i> Change
                        </button>
                      </div>
                    </div>

                    <% if (user && user.admin) { %>
                      <div class="customization-section">
                        <div class="customization-section-header">
                          <div class="customization-section-info">
                            <div class="customization-section-icon" style="background-color: none; background: none;">
                              <img
                                src="<%= (branding && branding.loginWatermarkUrl) ? branding.loginWatermarkUrl : 'https://cdn.jsdelivr.net/gh/antonndev/ADCDn/watermark.webp' %>"
                                alt="Login Watermark" width="47px" height="47px"
                                style="width: 47px; height: 47px; object-fit: contain;" data-login-watermark-image>
                            </div>
                            <div>
                              <div class="customization-section-title">Login watermark</div>
                              <div class="customization-section-desc">Turn ADPanel into your brand</div>
                            </div>
                          </div>
                          <button class="btn" id="openLoginWatermarkBtn" title="Change login watermark">
                            <i class="fa-solid fa-image"></i> Change Watermark
                          </button>
                        </div>
                      </div>

                      <div class="customization-section">
                        <div class="customization-section-header">
                          <div class="customization-section-info">
                            <div class="customization-section-icon">
                              <i class="fa-solid fa-photo-film"></i>
                            </div>
                            <div>
                              <div class="customization-section-title">Login background</div>
                              <div class="customization-section-desc">Set the scene before sign-in.</div>
                            </div>
                          </div>
                          <button class="btn" id="openLoginBackgroundBtn" title="Change login background">
                            <i class="fa-solid fa-panorama"></i> Change Background
                          </button>
                        </div>
                      </div>

                      <div class="customization-section">
                        <div class="customization-section-header">
                          <div class="customization-section-info">
                            <div class="customization-section-icon" style="background-color: none; background: none;">
                              <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/alert.webp" alt="Global Alert"
                                width="55px" height="47px">
                            </div>
                            <div>
                              <div class="customization-section-title">Global Alert</div>
                              <div class="customization-section-desc">Inform users about an alert or a maintenance</div>
                            </div>
                          </div>
                          <button class="btn" id="openAlertModalBtn" title="Set Alert"
                            style="display: flex; align-items: center; gap: 6px;">
                            <span>Add Alert</span>
                          </button>
                        </div>
                      </div>
                      <% } %>

              </div>

              <div id="account" class="panel-section">
                <div class="account-header">
                  <div>
                    <div class="account-title">Account</div>
                    <div class="account-subtitle">ADPanel helps you to manage all users, simplified.</div>
                  </div>
                  <button id="logoutBtn" class="logout-btn-modern"><i
                      class="fa-solid fa-right-from-bracket"></i><span>Log Out</span></button>
                </div>

                <div class="account-content">

                  <div id="changePassCard" class="clickable-card change-pass-card">
                    <div class="change-pass-header">
                      <div>
                        <div class="change-pass-title">Change password</div>
                        <small class="change-pass-subtitle">Requires current password & 2FA.</small>
                      </div>
                      <div class="change-pass-icon"><i class="fa-solid fa-key"></i></div>
                    </div>
                  </div>

                  <div class="note-box">
                    <strong>NOTE:</strong> Other settings like admin-user creation are changed via the
                    <code>initialize.sh</code>
                  </div>

                  <div id="accountsSection" class="accounts-section">
                    <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 15px;">
                      <div>
                        <div class="accounts-title" style="margin-bottom: 0;">Accounts</div>
                      </div>
                      <button class="btn ghost" id="openCreateUserBtn" title="Create new user"
                        style="display: flex; align-items: center; gap: 6px; color: white; margin-bottom: 0;">
                        <i class="fa-solid fa-user-plus"></i> Create User
                      </button>
                    </div>
                    <div class="accounts-search-container">
                      <i class="fa-solid fa-search accounts-search-icon"></i>
                      <input type="text" id="accountsSearchInput" class="accounts-search-input"
                        placeholder="Search accounts by email...">
                    </div>
                    <div id="accountsList" class="accounts-list">
                    </div>
                  </div>

                </div>
              </div>

              <div id="security" class="panel-section">
                <div class="security-title">Security</div>
                <div class="security-subtitle">ADPanel helps you to handle attacks</div>

                <div class="security-card" id="rateLimiterCard">
                  <div class="security-card-inner">
                    <div class="security-card-left">
                      <div class="security-card-icon security-card-icon-rate"></div>
                      <div>
                        <div class="security-card-title">Rate Limiter</div>
                        <div class="security-card-desc">Limit requests per IP to prevent abuse</div>
                      </div>
                    </div>
                    <label class="switch">
                      <input type="checkbox" id="rateLimiterToggle">
                      <span class="slider"></span>
                    </label>
                  </div>

                  <div id="rateLimiterDetails" class="security-details">
                    <div class="security-details-grid">
                      <div class="security-details-row">
                        <div class="security-details-col">
                          <label class="security-details-label">
                            <i class="fa-solid fa-hashtag"></i> Max requests
                          </label>
                          <input type="number" id="rateLimiterLimit" min="1" max="10000" value="5"
                            class="security-details-input" placeholder="5">
                        </div>
                        <div class="security-details-col">
                          <label class="security-details-label">
                            <i class="fa-solid fa-clock"></i> Window (seconds)
                          </label>
                          <input type="number" id="rateLimiterWindow" min="1" max="86400" value="120"
                            class="security-details-input" placeholder="120">
                        </div>
                      </div>
                      <div class="security-details-footer">
                        <div class="security-summary">
                          <i class="fa-solid fa-info-circle"></i>
                          <span id="rateLimiterSummary">5 requests per 120 seconds</span>
                        </div>
                        <button class="btn security-save-btn" id="rateLimiterSave">
                          <i class="fa-solid fa-floppy-disk"></i> Save
                        </button>
                      </div>
                      <div id="rateLimiterFeedback" class="security-feedback"></div>
                    </div>
                  </div>
                </div>

                <div class="security-card security-card-mt-sm" id="captchaCard">
                  <div class="security-card-inner">
                    <div class="security-card-left">
                      <div class="security-card-icon security-card-icon-captcha"></div>
                      <div>
                        <div class="security-card-title">Enable captcha at login</div>
                        <div class="security-card-desc">Protect against simple bots using reCAPTCHA/Turnstile/hCaptcha</div>
                      </div>
                    </div>
                    <label class="switch">
                      <input type="checkbox" id="captchaToggle">
                      <span class="slider"></span>
                    </label>
                  </div>

                  <div id="captchaDetails" class="security-details">
                    <div class="captcha-active-box">
                      <i class="fa-solid fa-check-circle captcha-active-icon"></i>
                      <span class="captcha-active-text">Captcha is configured and active</span>
                    </div>
                    <div class="captcha-info">
                      <i class="fa-solid fa-info-circle"></i> To update keys, toggle off and back on.
                    </div>
                  </div>
                </div>

                <% if (user && user.admin) { %>
                <div class="security-card security-card-mt-sm" id="maintenanceCard">
                  <div class="security-card-inner">
                    <div class="security-card-left">
                      <div class="security-card-icon security-card-icon-maintenance">
                        <i class="fa-solid fa-wrench" style="font-size: 20px; color: #f59e0b; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;"></i>
                      </div>
                      <div>
                        <div class="security-card-title">Maintenance Mode</div>
                        <div class="security-card-desc">Lock the panel for non-admin users during updates or fixes</div>
                      </div>
                    </div>
                    <label class="switch">
                      <input type="checkbox" id="maintenanceToggle">
                      <span class="slider"></span>
                    </label>
                  </div>

                  <div id="maintenanceDetails" class="security-details">
                    <div id="maintenanceActiveBox" class="captcha-active-box" style="display:none; background: rgba(245, 158, 11, 0.1);">
                      <i class="fa-solid fa-wrench" style="color: #f59e0b;"></i>
                      <span style="font-size: 13px; color: #f59e0b;" id="maintenanceActiveText">Maintenance mode is active</span>
                    </div>
                    <div id="maintenanceScheduledBox" class="captcha-active-box" style="display:none; background: rgba(59, 130, 246, 0.1); margin-top: 8px;">
                      <i class="fa-solid fa-calendar-days" style="color: #3b82f6;"></i>
                      <span style="font-size: 13px; color: #3b82f6;" id="maintenanceScheduledText">Scheduled for ...</span>
                    </div>
                    <div class="captcha-info" style="margin-top: 12px;">
                      <i class="fa-solid fa-info-circle"></i> When active, all non-admin users will see a maintenance page and cannot access any panel features. Admins can still use the panel normally. The setting persists across panel restarts.
                    </div>
                  </div>
                </div>
                <% } %>

              </div>

              <% if (user && user.admin) { %>
              <div id="sessions" class="panel-section">
                <div class="sessions-panel-header">
                  <div>
                    <div class="sessions-panel-title">Sessions</div>
                    <div class="sessions-panel-subtitle">Manage all ADPanel Sessions.</div>
                  </div>
                  <div class="security-sessions-header-meta">
                    <span class="security-inline-chip" id="sessionsCountBadge">0 active</span>
                  </div>
                </div>

                <div class="security-card security-sessions-card sessions-standalone-card">
                  <div class="sessions-toolbar">
                    <div class="accounts-search-container sessions-search-container">
                      <i class="fa-solid fa-search accounts-search-icon"></i>
                      <input type="text" id="sessionsSearchInput" class="accounts-search-input"
                        placeholder="Search by Email" autocomplete="off" spellcheck="false">
                    </div>
                    <div id="sessionsSummary" class="security-summary sessions-summary">
                      Loading active browser sessions...
                    </div>
                  </div>

                  <div id="sessionsFeedback" class="security-feedback sessions-feedback"></div>

                  <div id="sessionsList" class="sessions-list">
                    <div class="sessions-empty-state">
                      <i class="fa-solid fa-spinner fa-spin"></i>
                      <span>Loading active sessions...</span>
                    </div>
                  </div>

                  <div id="sessionsPagination" class="sessions-pagination"></div>
                </div>
              </div>
              <% } %>

              <div id="databases" class="panel-section">
                <div class="databases-header">
                  <div>
                    <div class="databases-title">Database Management</div>
                    <div class="databases-subtitle">Install and manage database servers</div>
                  </div>
                </div>

                <div class="databases-content">
                  <div class="security-card" id="phpmyadminCard">
                    <div class="security-card-inner">
                      <div class="security-card-left">
                        <div class="security-card-icon db-card-icon-phpmyadmin"><img
                            src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/phpmyadmin.webp"
                            alt="phpMyAdmin" width="45px" height="45px"></div>
                        <div>
                          <div class="security-card-title">phpMyAdmin</div>
                          <div class="security-card-desc">MySQL/MariaDB web management interface</div>
                        </div>
                      </div>
                      <label class="switch">
                        <input type="checkbox" id="phpmyadminToggle">
                        <span class="slider"></span>
                      </label>
                    </div>

                    <div id="phpmyadminDetails" class="security-details db-details">
                      <div id="phpmyadminStatus" class="db-status-box">
                        <div class="db-status-loading">
                          <i class="fa-solid fa-spinner fa-spin"></i>
                          <span>Checking status...</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div id="dbUsersSection" class="db-users-section" style="display: none;">
                    <div class="db-users-header">
                      <div>
                        <div class="db-users-title">MySQL Users</div>
                        <div class="db-users-subtitle">Manage phpMyAdmin user accounts</div>
                      </div>
                      <button class="btn" id="addDbUserBtn"><i class="fa-solid fa-plus"></i> Add User</button>
                    </div>
                    <div id="dbUsersList" class="db-users-list">
                      <div class="db-users-empty">
                        <i class="fa-solid fa-user-slash"></i>
                        <p>No database users configured</p>
                      </div>
                    </div>
                  </div>

                  <div id="phpmyadminAccessSection" class="db-access-section" style="display: none;">
                    <div class="db-access-header">
                      <div class="db-access-icon success"><i class="fa-solid fa-check-circle"></i></div>
                      <div>
                        <div class="db-access-title">phpMyAdmin ready!</div>
