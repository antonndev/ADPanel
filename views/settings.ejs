          <p class="enterprise-modal-subtitle">Show a notice to all users.</p>
        </div>
        <button class="enterprise-modal-close" id="closeAlertModal" aria-label="Close">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="enterprise-modal-body">
        <div class="node-form-section">
          <div class="node-form-section-title">Existing Alerts</div>
          <div id="alertsList"
            style="display: flex; flex-direction: column; gap: 8px; max-height: 200px; overflow-y: auto; margin-bottom: 16px;">
            <div style="color: #6b7280; font-size: 13px; text-align: center; padding: 10px;">Loading...</div>
          </div>
        </div>

        <div class="node-form-section" style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 16px;">
          <div class="node-form-section-title"><i class="fa-solid fa-plus"></i> Schedule New Alert</div>
          <div class="node-form-grid alert-schedule-grid">
            <div class="node-form-field">
              <label class="node-form-label">Start Date</label>
              <input type="datetime-local" id="alertDate" class="node-form-input">
            </div>
            <div class="node-form-field">
              <label class="node-form-label">End Date</label>
              <input type="datetime-local" id="alertEndDate" class="node-form-input">
            </div>
          </div>
          <div class="node-form-section" style="margin-top: 12px; margin-bottom: 0;">
            <div class="maintenance-alert-toggle-row">
              <div>
                <div class="node-form-label" style="font-size: 13px;">Keep active until removed</div>
              </div>
              <label class="switch switch-sm">
                <input type="checkbox" id="alertNeverEnds" checked>
                <span class="slider"></span>
              </label>
            </div>
          </div>
          <div class="node-form-field" style="margin-top: 12px;">
            <label class="node-form-label">Message</label>
            <input type="text" id="alertContent" class="node-form-input" placeholder="e.g. Maintenance at 10 PM" />
          </div>
          <button id="addAlertBtn" class="enterprise-btn-primary" style="width: 100%; margin-top: 16px;">
            <i class="fa-solid fa-plus"></i> Add Alert
          </button>
        </div>
      </div>

      <div class="enterprise-modal-footer">
        <button id="closeAlertModalFooter" class="enterprise-btn-secondary">Close</button>
      </div>
    </div>
  </div>

  <div id="webhookModalOverlay" class="modal-overlay enterprise-modal-overlay" aria-hidden="true">
    <div class="enterprise-modal" id="webhookModal" style="width: 520px;">
      <div class="enterprise-modal-header">
        <div class="enterprise-modal-icon" style="background: transparent;">
          <img
            src="https://assets-global.website-files.com/6257adef93867e50d84d30e2/636e0a6a49cf127bf92de1e2_icon_clyde_blurple_RGB.png"
            alt="Discord" style="width: 60px; height: 60px; object-fit: contain;">
        </div>
        <div class="enterprise-modal-titles">
          <h3 class="enterprise-modal-title" id="webhookModalTitle">Add Webhook</h3>
          <p class="enterprise-modal-subtitle" id="webhookModalSubtitle">Paste a Discord webhook URL.</p>
        </div>
        <button class="enterprise-modal-close" id="webhookModalClose" aria-label="Close">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="enterprise-modal-body" style="padding: 24px;">
        <div id="webhookModeIndicator" style="display: none; margin-bottom: 16px;">
          <div
            style="display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: rgba(99,102,241,0.1); border-radius: 10px; border: 1px solid rgba(99,102,241,0.2);">
            <i class="fa-solid fa-tag" style="color: #a5b4fc;"></i>
            <span style="font-size: 13px; color: rgba(255,255,255,0.8);">Category: <strong
                id="webhookCategoryLabel"></strong></span>
          </div>
        </div>

        <div style="margin-bottom: 16px;">
          <label
            style="display: block; font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.7); margin-bottom: 8px;">
            Webhook URL
          </label>
          <input type="url" id="webhookUrlInput" placeholder="https://discord.com/api/webhooks/..."
            style="width: 100%; height: 48px; padding: 0 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.2); color: rgba(255,255,255,0.95); font-size: 14px; outline: none;">
        </div>

        <div style="background: rgba(59, 130, 246, 0.1); border-radius: 8px; padding: 12px; margin-top: 12px;">
          <i class="fa-solid fa-circle-info" style="color: #3b82f6; margin-right: 8px;"></i>
          <span style="font-size: 13px; color: rgba(255,255,255,0.8);">Paste a Discord webhook URL. Go to your Discord
            server → Channel Settings → Integrations → Webhooks → New Webhook.</span>
        </div>

        <div id="webhookModalError" style="display: none; color: #f44747; font-size: 13px; margin-top: 12px;"></div>
      </div>

      <div class="enterprise-modal-footer">
        <button class="enterprise-btn-secondary" id="webhookModalCancel">Cancel</button>
        <button class="enterprise-btn-primary" id="webhookModalSave"><i class="fa-solid fa-check"></i> Save
          Webhook</button>
      </div>
    </div>
  </div>

  <div id="webhookDeleteOverlay" class="modal-overlay enterprise-modal-overlay" aria-hidden="true">
    <div class="enterprise-modal" id="webhookDeleteModal" style="width: 420px;">
      <div class="enterprise-modal-header">
        <div class="enterprise-modal-icon" style="background: transparent;">
          <img src="https://cdn.jsdelivr.net/gh/antonndev/ADCDn/alert.webp" alt="Global Alert" width="80px"
            height="70px">
        </div>
        <div class="enterprise-modal-titles">
          <h3 class="enterprise-modal-title">Delete Webhook</h3>
          <p class="enterprise-modal-subtitle">This action cannot be undone</p>
        </div>
        <button class="enterprise-modal-close" id="webhookDeleteClose" aria-label="Close">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="enterprise-modal-body" style="padding: 24px;">
        <div style="background: rgba(239, 68, 68, 0.1); border-radius: 8px; padding: 12px;">
          <i class="fa-solid fa-triangle-exclamation" style="color: #f87171; margin-right: 8px;"></i>
          <span style="font-size: 13px; color: rgba(255,255,255,0.8);" id="webhookDeleteText">Are you sure you want to
            remove this webhook?</span>
        </div>
      </div>

      <div class="enterprise-modal-footer">
        <button class="enterprise-btn-secondary" id="webhookDeleteCancelBtn">Cancel</button>
        <button class="enterprise-btn-primary" id="webhookDeleteConfirmBtn" style="background: #ef4444;"><i
            class="fa-solid fa-trash"></i> Delete</button>
      </div>
    </div>
  </div>

</body>

</html>
