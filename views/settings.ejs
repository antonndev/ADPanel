        <div class="node-form-section">
          <div class="node-form-section-title"><i class="fa-solid fa-bell"></i> Pre-Alert</div>
          <div class="maintenance-alert-toggle-row">
            <div>
              <div class="node-form-label" style="font-size: 13px;">Show an alert before maintenance?</div>
              <span class="node-form-hint">Displays a banner alert on the dashboard to give users a heads-up</span>
            </div>
            <label class="switch switch-sm">
              <input type="checkbox" id="maintenancePreAlertToggle">
              <span class="slider"></span>
            </label>
          </div>
        </div>

        <div id="maintenancePreAlertGroup" style="display: none;">
          <div class="node-form-section">
            <div class="node-form-grid">
              <div class="node-form-field">
                <label class="node-form-label">Alert message</label>
                <input type="text" id="maintenancePreAlertMessage" class="node-form-input" placeholder="e.g. Scheduled maintenance in 30 minutes" maxlength="300">
              </div>
              <div class="node-form-field">
                <label class="node-form-label">Minutes before</label>
                <input type="number" id="maintenancePreAlertMinutes" class="node-form-input" placeholder="30" min="1" max="525600" value="30">
              </div>
            </div>
            <span class="node-form-hint" style="margin-top: 8px; display: block;">The alert will appear this many minutes before the scheduled time. After maintenance ends, your previous alert will be restored automatically.</span>
          </div>
        </div>

        <div class="maintenance-security-notice">
          <div class="maintenance-security-notice-inner">
            <i class="fa-solid fa-shield-halved"></i>
            <div>
              <strong>Note:</strong> This action is server-side and you cannot disable it without accesing the settings back.
            </div>
          </div>
        </div>

        <div id="maintenanceModalFeedback" class="node-feedback"></div>
      </div>

      <div class="enterprise-modal-footer">
        <button class="enterprise-btn-secondary" id="maintenanceModalCancel">Cancel</button>
        <button class="enterprise-btn-primary maintenance-btn-enable" id="maintenanceModalSave">
          <i class="fa-solid fa-wrench"></i> Enable Maintenance
        </button>
      </div>
    </div>
  </div>

