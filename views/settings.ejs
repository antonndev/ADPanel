          <div class="node-form-grid">
            <div class="node-form-field">
              <label class="node-form-label">Template name</label>
              <input id="ct_name" type="text" class="node-form-input" placeholder="e.g. Minecraft Server" />
            </div>
            <div class="node-form-field">
              <label class="node-form-label">Template ID</label>
              <input id="ct_id" type="text" class="node-form-input" placeholder="lowercase, a-z 0-9 - _" />
            </div>
          </div>
          <div class="node-form-field" style="margin-top: 12px;">
            <label class="node-form-label">Description</label>
            <textarea id="ct_description" class="node-form-textarea"
