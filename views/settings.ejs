          </div>
        </div>

        <div class="node-form-section">
          <div class="node-form-section-title"><i class="fa-brands fa-docker"></i> Docker Configuration</div>
          <div class="node-form-grid">
            <div class="node-form-field">
              <label class="node-form-label">Docker image</label>
              <input id="ct_image" type="text" class="node-form-input"
                placeholder="e.g. spritsail/fivem, node, python" />
            </div>
            <div class="node-form-field">
              <label class="node-form-label">Tag</label>
              <input id="ct_tag" type="text" class="node-form-input" placeholder="latest" value="latest" />
            </div>
          </div>
          <div class="node-form-field" style="margin-top: 12px;">
            <label class="node-form-label">Startup command</label>
            <textarea id="ct_startup_command" class="node-form-textarea" aria-describedby="ct_startupCommandHelp" placeholder="e.g. node /app/index.js"></textarea>
            <small id="ct_startupCommandHelp" class="startup-cmd-help">Use only the in-container executable and arguments. Docker CLI commands like <code>docker run</code> are blocked.</small>
          </div>
          <div class="node-form-field" style="margin-top: 12px;">
            <label class="node-form-label">Workdir</label>
            <input id="ct_workdir" type="text" class="node-form-input" placeholder="e.g. /app" />
          </div>
        </div>

        <div class="node-form-section">
          <div class="node-form-section-title"><i class="fa-solid fa-image"></i> Appearance</div>
          <div class="node-form-field">
